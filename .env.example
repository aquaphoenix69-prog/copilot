# --- Neo4j AuraDB (free tier) ---
# After creating a free instance at https://console.neo4j.io/
# you'll get a Bolt URI like: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=neo4j+s://REPLACE_ME.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME

# --- LLM (Ollama, OpenAI-compatible) ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_API_KEY=ollama

# --- Local model checkpoints ---
INTERPRETER_MODEL=microsoft/deberta-v3-base
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
STT_MODEL=nvidia/parakeet-tdt-0.6b-v2

# --- Dataset path ---
DATASET_PATH=C:/Users/aquap/Downloads/final_master_dataset_complete_final.json

DEVICE=cuda
LOG_LEVEL=INFO
